# Average SMP by month
monthly_smp = df.groupby("Month")["SMP (TL/MWh)"].mean()
plt.figure(figsize=(8, 5))
plt.plot(monthly_smp.index, monthly_smp.values, marker="o")
plt.xlabel("Month")
plt.ylabel("Average SMP")
plt.title("Average SMP by Month")
plt.xticks(range(1, 13))
plt.tight_layout()
plt.savefig("project_outputs/monthly_smp.png", dpi=300)
plt.close()

# Average SMP by time group
timegroup_smp = df.groupby("TimeGroup")["SMP (TL/MWh)"].mean().reindex(["Night", "Morning", "Afternoon", "Evening"])
plt.figure(figsize=(8, 5))
plt.bar(timegroup_smp.index, timegroup_smp.values)
plt.xlabel("Time Group")
plt.ylabel("Average SMP")
plt.title("Average SMP by Time Group")
plt.tight_layout()
plt.savefig("project_outputs/timegroup_smp.png", dpi=300)
plt.close()

# Correlation by time group
corr_by_group = df.groupby("TimeGroup").apply(
    lambda x: x["MCP (TL/MWh)"].corr(x["SMP (TL/MWh)"])
).reindex(["Night", "Morning", "Afternoon", "Evening"])

plt.figure(figsize=(8, 5))
plt.bar(corr_by_group.index, corr_by_group.values)
plt.xlabel("Time Group")
plt.ylabel("Correlation")
plt.title("MCP-SMP Correlation by Time Group")
plt.tight_layout()
plt.savefig("project_outputs/correlation_by_timegroup.png", dpi=300)
plt.close()


# Hypothesis tests

results = []

# H1: Average MCP is the same across all months
groups_mcp_month = [g["MCP (TL/MWh)"].values for _, g in df.groupby("Month")]
stat1, p1 = f_oneway(*groups_mcp_month)
results.append([
    "H1: Average MCP is the same across all months",
    "One-way ANOVA",
    round(stat1, 4),
    p1,
    "Reject H0" if p1 < 0.05 else "Fail to reject H0"
])

# H2: MCP-SMP correlation is the same across all time groups
interaction_model = smf.ols('Q("SMP (TL/MWh)") ~ Q("MCP (TL/MWh)") * C(TimeGroup)', data=df).fit()
anova_interaction = smf.ols('Q("SMP (TL/MWh)") ~ Q("MCP (TL/MWh)") + C(TimeGroup)', data=df).fit()
# Compare models to test interaction terms (This was recommended by AI)
from statsmodels.stats.anova import anova_lm
interaction_test = anova_lm(anova_interaction, interaction_model)
stat2 = interaction_test.iloc[1]["F"]
p2 = interaction_test.iloc[1]["Pr(>F)"]
results.append([
    "H2: MCP-SMP correlation is the same across all time groups",
    "Interaction regression test",
    round(stat2, 4),
    p2,
    "Reject H0" if p2 < 0.05 else "Fail to reject H0"
])

# H3: Average SMP is the same across all time groups
groups_smp_time = [g["SMP (TL/MWh)"].values for _, g in df.groupby("TimeGroup")]
stat3, p3 = f_oneway(*groups_smp_time)
results.append([
    "H3: Average SMP is the same across all time groups",
    "One-way ANOVA",
    round(stat3, 4),
    p3,
    "Reject H0" if p3 < 0.05 else "Fail to reject H0"
])

# H4: Average SMP is the same across all months
groups_smp_month = [g["SMP (TL/MWh)"].values for _, g in df.groupby("Month")]
stat4, p4 = f_oneway(*groups_smp_month)
results.append([
    "H4: Average SMP is the same across all months",
    "One-way ANOVA",
    round(stat4, 4),
    p4,
    "Reject H0" if p4 < 0.05 else "Fail to reject H0"
])

# Extra overall relationship test
corr, p_corr = pearsonr(df["MCP (TL/MWh)"], df["SMP (TL/MWh)"])
results.append([
    "Extra: MCP and SMP are linearly related overall",
    "Pearson correlation",
    round(corr, 4),
    p_corr,
    "Reject H0" if p_corr < 0.05 else "Fail to reject H0"
])

results_df = pd.DataFrame(results, columns=["Hypothesis", "Test", "Statistic", "P-value", "Decision"])
results_df["P-value"] = results_df["P-value"].apply(lambda x: f"{x:.4e}")
results_df.to_csv("project_outputs/hypothesis_results.csv", index=False)

print("\nHypothesis test results:\n")
print(results_df.to_string(index=False))
print("\nGraphs were saved in the 'project_outputs' folder.")
