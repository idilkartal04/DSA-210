
import os
import warnings
import pandas as pd
import matplotlib.pyplot as plt
from scipy.stats import f_oneway, pearsonr
import statsmodels.formula.api as smf

warnings.filterwarnings("ignore")

#read the data
df = pd.read_excel("wind.xlsx")

#the hours and dates are different in the excel file, convert them into the proper types
df["HourNum"] = df["Hour"].astype(str).str.replace("H", "", regex=False).astype(int)
df["datetime"] = pd.to_datetime(df["Date"]) + pd.to_timedelta(df["HourNum"], unit="h")


#group the times of day together for correlation analysis
def get_time_group(hour):
    if 0 <= hour < 6:
        return "Night"
    elif 6 <= hour < 12:
        return "Morning"
    elif 12 <= hour < 18:
        return "Afternoon"
    else:
        return "Evening"

df["TimeGroup"] = df["HourNum"].apply(get_time_group)

os.makedirs("project_outputs", exist_ok=True)


# Graphs
# Histogram of MCP
plt.figure(figsize=(8, 5))
plt.hist(df["MCP (TL/MWh)"], bins=50)
plt.xlabel("MCP (TL/MWh)")
plt.ylabel("Frequency")
plt.title("Histogram of MCP")
plt.tight_layout()
plt.savefig("project_outputs/histogram_mcp.png", dpi=300)
plt.close()

# Histogram of SMP
plt.figure(figsize=(8, 5))
plt.hist(df["SMP (TL/MWh)"], bins=50)
plt.xlabel("SMP (TL/MWh)")
plt.ylabel("Frequency")
plt.title("Histogram of SMP")
plt.tight_layout()
plt.savefig("project_outputs/histogram_smp.png", dpi=300)
plt.close()

# 3) Sample of MCP vs SMP scatter plot (too many data points, the actual plot of the values resulted in a plot that was hard to read)
sample_df = df.sample(n=min(5000, len(df)), random_state=42)
plt.figure(figsize=(7, 6))
plt.scatter(sample_df["MCP (TL/MWh)"], sample_df["SMP (TL/MWh)"], alpha=0.3)
plt.xlabel("MCP (TL/MWh)")
