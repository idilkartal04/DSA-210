# 4) Average MCP by month
monthly_mcp = df.groupby("Month")["MCP (TL/MWh)"].mean()
plt.figure(figsize=(8, 5))
plt.plot(monthly_mcp.index, monthly_mcp.values, marker="o")
plt.xlabel("Month")
